<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_home"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export_keys_title"
            android:textColor="@color/text_light"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/export_keys_warning"
            android:textColor="#FFD54F"
            android:textSize="13sp" />

        <!-- Seed phrase (24 words) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/export_keys_label_seed"
            android:textColor="@color/text_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_seed_phrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/background_balance_detail_amounts_container"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textColor="@color/text_light"
            android:textIsSelectable="true"
            android:textSize="14sp"
            tools:ignore="UnusedAttribute" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_copy_seed"
            style="@style/Zcash.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/export_keys_copy_seed"
            android:textColor="@color/text_light" />

        <!-- Birthday height -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/export_keys_label_birthday"
            android:textColor="@color/text_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_birthday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:textColor="@color/text_light"
            android:textIsSelectable="true"
            android:textSize="14sp"
            tools:ignore="UnusedAttribute" />

        <!-- Sapling spending key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/export_keys_label_spending_key"
            android:textColor="@color/text_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_spending_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/background_balance_detail_amounts_container"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textColor="@color/text_light"
            android:textIsSelectable="true"
            android:textSize="13sp"
            tools:ignore="UnusedAttribute" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_copy_spending_key"
            style="@style/Zcash.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/export_keys_copy_key"
            android:textColor="@color/text_light" />

        <!-- Shielded address (for verification) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/export_keys_label_address"
            android:textColor="@color/text_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/background_balance_detail_amounts_container"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textColor="@color/text_light"
            android:textIsSelectable="true"
            android:textSize="13sp"
            tools:ignore="UnusedAttribute" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_copy_address"
            style="@style/Zcash.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/export_keys_copy_address"
            android:textColor="@color/text_light" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_done"
            style="@style/Zcash.Button.OutlinedButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/done"
            android:textColor="@color/colorPrimary" />

    </LinearLayout>
</ScrollView>
